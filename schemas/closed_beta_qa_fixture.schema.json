{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Closed Beta QA Fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "synthetic",
    "not_copied_from_real_chat",
    "input",
    "expected_cue",
    "expected_span",
    "required_safe_phrases",
    "forbidden_outputs",
    "safe_output",
    "screenshot_allowed"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^qa_[a-z0-9_]+$"
    },
    "synthetic": {
      "const": true
    },
    "not_copied_from_real_chat": {
      "const": true
    },
    "input": {
      "type": "string",
      "minLength": 1
    },
    "expected_cue": {
      "type": "string",
      "minLength": 1
    },
    "expected_span": {
      "type": "string"
    },
    "required_safe_phrases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safe_output": {
      "type": "string",
      "minLength": 1
    },
    "screenshot_allowed": {
      "const": true
    }
  }
}
