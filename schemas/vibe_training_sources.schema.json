{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-signal.local/schemas/vibe_training_sources.schema.json",
  "title": "Vibe Training Sources Rights Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["training_sources_version", "description", "sources"],
  "properties": {
    "training_sources_version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "source_id",
          "name",
          "modality",
          "task",
          "license_name",
          "license_url",
          "download_method",
          "access_notes",
          "training_use_allowed",
          "commercial_use_allowed",
          "research_only",
          "rights_tier",
          "safe_vibe_use",
          "blocked_vibe_use",
          "registry_status",
          "notes"
        ],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "modality": { "type": "string", "minLength": 1 },
          "task": { "type": "string", "minLength": 1 },
          "license_name": { "type": "string", "minLength": 1 },
          "license_url": { "type": "string", "minLength": 1 },
          "download_method": { "type": "string", "minLength": 1 },
          "access_notes": { "type": "string", "minLength": 1 },
          "training_use_allowed": { "type": "boolean" },
          "commercial_use_allowed": { "type": "boolean" },
          "research_only": { "type": "boolean" },
          "rights_tier": {
            "type": "string",
            "enum": ["open", "NC", "manual-review", "restricted", "eval-only", "unknown", "synthetic_fixture"]
          },
          "usage": { "type": "string" },
          "safe_vibe_use": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "blocked_vibe_use": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "registry_status": { "type": "string", "minLength": 1 },
          "notes": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
