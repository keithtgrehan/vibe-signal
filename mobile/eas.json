{
  "cli": {
    "version": ">= 19.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vibe-signal.onrender.com",
        "EXPO_PUBLIC_QA_FIXTURE_MODE": "",
        "EXPO_PUBLIC_ENABLE_RAW_LOGS": "false",
        "EXPO_PUBLIC_ENABLE_ANALYTICS": "false"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vibe-signal.onrender.com",
        "EXPO_PUBLIC_QA_FIXTURE_MODE": "closed_beta_synthetic",
        "EXPO_PUBLIC_ENABLE_RAW_LOGS": "false",
        "EXPO_PUBLIC_ENABLE_ANALYTICS": "false"
      },
      "ios": {
        "simulator": true
      }
    },
    "qa": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vibe-signal.onrender.com",
        "EXPO_PUBLIC_QA_FIXTURE_MODE": "closed_beta_synthetic",
        "EXPO_PUBLIC_ENABLE_RAW_LOGS": "false",
        "EXPO_PUBLIC_ENABLE_ANALYTICS": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vibe-signal.onrender.com",
        "EXPO_PUBLIC_QA_FIXTURE_MODE": "",
        "EXPO_PUBLIC_ENABLE_RAW_LOGS": "false",
        "EXPO_PUBLIC_ENABLE_ANALYTICS": "false"
      }
    },
    "testflight": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vibe-signal.onrender.com",
        "EXPO_PUBLIC_QA_FIXTURE_MODE": "",
        "EXPO_PUBLIC_ENABLE_RAW_LOGS": "false",
        "EXPO_PUBLIC_ENABLE_ANALYTICS": "false"
      }
    }
  },
  "submit": {
    "production": {},
    "testflight": {}
  }
}
