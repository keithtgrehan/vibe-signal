# Vibe Signal backend deployment environment example.
# This file is documentation only. Do not put secrets in it.

# local | staging | production
VIBE_BACKEND_ENV=staging

# Free-form release label surfaced by GET /readyz.
VIBE_BACKEND_VERSION=0.1.0

# Comma-separated exact browser origins for CORS.
# Native mobile clients do not use browser CORS, but Expo web or browser-based
# admin/testing surfaces do. Use exact http(s) origins; do not use '*'.
# Local PR #17 browser QA against the Render backend needs Expo web, Metro web,
# and standalone Vite origins explicitly listed.
VIBE_BACKEND_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:5173
# Future hosted web/admin frontends must be added as exact origins, for example:
# VIBE_BACKEND_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# DEBUG | INFO | WARNING | ERROR | CRITICAL
# Logs must stay metadata-only. Do not log request bodies, raw chat text,
# provider responses, credentials, tokens, or model artifacts.
VIBE_BACKEND_LOG_LEVEL=INFO

# Mobile build/runtime configuration lives in the Expo environment, not the
# backend process:
# EXPO_PUBLIC_API_URL=https://api.example.com
# EXPO_PUBLIC_ENABLE_LOGGING=false
