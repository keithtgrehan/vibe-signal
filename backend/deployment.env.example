# Vibe Signal backend deployment environment example.
# This file is documentation only. Do not put secrets in it.

# local | staging | production
VIBE_BACKEND_ENV=staging

# Render Python runtime version for hosted backend deploys.
PYTHON_VERSION=3.11.11

# Free-form release label surfaced by GET /readyz.
VIBE_BACKEND_VERSION=0.1.0

# Optional non-secret deploy identity surfaced by GET /api/status.
# Use these to compare a deployed Render backend with the local Git commit.
# Values are sanitized and unsafe-looking values return "unknown".
# Do not put secrets, tokens, internal URLs, usernames, local paths, raw chat
# text, or private data in these variables.
GIT_COMMIT=unknown
DEPLOY_VERSION=unknown
BUILD_TIMESTAMP=unknown
SERVICE_REVISION=unknown

# Comma-separated exact browser origins for CORS.
# Native mobile clients do not use browser CORS, but Expo web or browser-based
# admin/testing surfaces do. Use exact http(s) origins; do not use '*'.
# Hosted web and local browser QA against the Render backend need exact origins
# explicitly listed.
VIBE_BACKEND_ALLOWED_ORIGINS=https://www.vibe-signal.com,https://vibe-signal.com,https://vibe-signal.vercel.app,http://localhost:19006,http://localhost:8081,http://localhost:5173,http://127.0.0.1:5173
# Future hosted web/admin frontends must be added as exact origins, for example:
# VIBE_BACKEND_ALLOWED_ORIGINS=https://vibe-signal.vercel.app,https://app.example.com,https://admin.example.com

# DEBUG | INFO | WARNING | ERROR | CRITICAL
# Logs must stay metadata-only. Do not log request bodies, raw chat text,
# provider responses, credentials, tokens, or model artifacts.
VIBE_BACKEND_LOG_LEVEL=INFO

# Mobile build/runtime configuration lives in the Expo environment, not the
# backend process:
# EXPO_PUBLIC_API_URL=https://api.example.com
# EXPO_PUBLIC_ENABLE_LOGGING=false
